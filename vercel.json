{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/landing.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/", "destination": "/landing.html" },
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/(.*)", "destination": "/index.html" },
    { "source": "/((?!api/|landing\\.html).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/bookings?cron=send-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/bookings?cron=weekly-summary",
      "schedule": "0 9 * * 0"
    }
  ]
}
